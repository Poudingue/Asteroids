ScenarioDef(
    name: "visual_test",
    seed: 99,
    target_fps: 60,
    mode: Interactive,
    setup: [
        SpawnAsteroid(pos: (300.0, 600.0), radius: 90.0, velocity: (15.0, -8.0)),
        SpawnAsteroid(pos: (960.0, 540.0), radius: 50.0, velocity: (-5.0, 12.0)),
        SpawnAsteroid(pos: (1400.0, 250.0), radius: 25.0, velocity: (-20.0, 18.0)),
        SetShipPosition(960.0, 540.0),
        SetShipAim(0.0),
    ],
    actions: [
        (frame: 0,   action: MoveDirection(0.0, 1.0)),
        (frame: 20,  action: AimAt(3.93)),
        (frame: 20,  action: Fire),
        (frame: 60,  action: MoveDirection(1.0, 0.0)),
        (frame: 90,  action: StopMoving),
        (frame: 100, action: Teleport),
    ],
    run_until: 120,
    snapshots_at: [0, 30, 60, 90, 120],
    trajectory_interval: 5,
    assertions: [
        (frame: 119, check: ShipAlive),
        (frame: 119, check: ObjectCountAtLeast(2)),
    ],
)
